# =============================================================================
# JARVIS Environment Configuration
# Copy this file to ~/.jarvis/.env and fill in real values.
#
# NOTE: launchd reads environment variables from com.jarvis.backend.plist,
#       not from this file. Keep ~/.jarvis/.env and the plist in sync.
#       The plist is the authoritative source for the launchd service.
# =============================================================================


# =============================================================================
# LLM / OpenAI
# =============================================================================

# OpenAI API key — used for escalation calls and Friday's voice sessions
# https://platform.openai.com/api-keys
OPENAI_API_KEY=YOUR-OPENAI-KEY-HERE

# Groq — ultra-fast cloud LLM for voice (840-1000 tok/s, free tier available)
# Used for task_type="voice" and "voice_quick" — 10x faster first token than Ollama
# Get a free key at: https://console.groq.com
GROQ_API_KEY=YOUR-GROQ-KEY-HERE
# JARVIS_GROQ_MODEL=llama-3.1-8b-instant   # default; llama-3.3-70b for higher quality

# Voice tool allowlist — comma-separated tool IDs available to FRIDAY during voice sessions
# Keeping this small reduces LLM prefill time and keeps voice snappy
# JARVIS_VOICE_TOOLS=briefing,weather,calendar,reminders,home_assistant,chronicle,timer,math

# Model aliases
OPENAI_MODEL=gpt-5.4-mini
OPENAI_TEXT_MODEL=gpt-5.4-mini
OPENAI_ROUTER_MODEL=gpt-5.4-nano
OPENAI_REALTIME_MODEL=gpt-realtime-1.5

# Escalation / high-complexity model (used when local reasoning is insufficient)
JARVIS_OPENAI_MODEL=gpt-5.4-mini


# =============================================================================
# Ollama — Local Model Configuration
# =============================================================================

# Ollama server base URL
OLLAMA_BASE_URL=http://localhost:11434/v1

# =============================================================================
# Monday Sandbox Intelligence
# =============================================================================

# Enable bounded Ollama intelligence in the Monday sandbox.
# This does not replace posture resolution or contract enforcement.
# It refines replies after the Monday engine has already chosen role + outcome.
MONDAY_OLLAMA_ENABLED=true
MONDAY_OLLAMA_BASE_URL=http://127.0.0.1:11434
MONDAY_OLLAMA_MODEL=qwen2.5:7b
MONDAY_OLLAMA_TIMEOUT_MS=15000

# Fast classification model (lightweight, low latency)
# Pull with: ollama pull phi3.5
JARVIS_OLLAMA_FAST_MODEL=phi3.5

# Main reasoning model
# NOTE: gpt-oss-20b may not be a published Ollama model name.
# setup.sh will fall back to 'openhermes' if unavailable.
# Update once the correct model ID is confirmed.
JARVIS_OLLAMA_REASONING_MODEL=gpt-oss-20b

# Second-brain / summarisation / background models
JARVIS_SECOND_BRAIN_ENABLED=true
JARVIS_SECOND_BRAIN_PROVIDER=ollama
JARVIS_SECOND_BRAIN_MODEL=qwen2.5:7b
JARVIS_OLLAMA_SUMMARIZE_MODEL=qwen2.5:7b
JARVIS_OLLAMA_BACKGROUND_MODEL=qwen2.5:7b


# =============================================================================
# Voice / Audio
# =============================================================================

# ElevenLabs TTS (optional — Kokoro is the default on-device TTS engine)
# https://elevenlabs.io
ELEVENLABS_API_KEY=YOUR-ELEVENLABS-KEY-HERE
ELEVENLABS_VOICE=Adam

# TTS provider chain
JARVIS_TTS_PROVIDER=piper
JARVIS_TTS_FALLBACKS=piper,localai,elevenlabs,system

# STT provider chain
JARVIS_STT_PROVIDER=openai
JARVIS_STT_FALLBACKS=localai

# Whisper STT model via mlx-whisper (Apple Silicon accelerated)
# Other options: mlx-community/whisper-base, mlx-community/whisper-small
JARVIS_MLX_WHISPER_MODEL=mlx-community/whisper-large-v3-turbo

# Kokoro TTS voice identifier (on-device, default)
# af_heart = warm female; other options: af_sky, am_adam, bf_emma
JARVIS_KOKORO_VOICE=af_heart

# Wake word model name / path
JARVIS_WAKE_WORD_MODEL=hey_jarvis

# Piper TTS — Friday's voice: en_US-hfc_female-medium (warm, clear, American English)
# Downloaded by setup.sh to ~/.jarvis/voices/
# https://huggingface.co/rhasspy/piper-voices/tree/main/en/en_US/hfc_female/medium
PIPER_BINARY=/Users/chris/Desktop/CODE/JARVIS/.venv/bin/piper
PIPER_MODEL_PATH=~/.jarvis/voices/en_US-hfc_female-medium.onnx
PIPER_SPEAKER=

# LocalAI (optional self-hosted fallback)
LOCALAI_BASE_URL=http://127.0.0.1:8080
LOCALAI_API_KEY=
LOCALAI_TTS_MODEL=jarvis-piper
LOCALAI_TTS_BACKEND=piper
LOCALAI_STT_MODEL=whisper-1

# LiveKit (optional real-time audio)
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=


# =============================================================================
# Scheduling / Quiet Hours
# =============================================================================

# Hour (24h) when JARVIS enters overnight quiet mode (proactive actions suppressed)
JARVIS_QUIET_HOURS_START=22

# Hour (24h) when quiet mode ends and JARVIS resumes normal operation
JARVIS_QUIET_HOURS_END=7


# =============================================================================
# Home Assistant
# =============================================================================

# Base URL for your Home Assistant instance
HOME_ASSISTANT_URL=http://homeassistant.local:8123

# launchd plist alias (both vars are read by different connectors)
HA_URL=http://homeassistant.local:8123

# Long-lived access token
# Generate at: HA Profile page → Long-Lived Access Tokens → Create Token
HOME_ASSISTANT_TOKEN=YOUR_HOME_ASSISTANT_LONG_LIVED_TOKEN
HA_TOKEN=YOUR_HOME_ASSISTANT_LONG_LIVED_TOKEN


# =============================================================================
# Google (Calendar + Gmail)
# =============================================================================

# Create OAuth credentials at: https://console.cloud.google.com
# → APIs & Services → Credentials → OAuth 2.0 Client ID
# Scopes required: calendar.readonly, gmail.readonly (adjust as needed)
GOOGLE_CLIENT_ID=your-google-client-id-here
GOOGLE_CLIENT_SECRET=your-google-client-secret-here
# Google Maps browser key. If omitted, JARVIS will also accept a shared Google key
# from GOOGLE_API_KEY or a GOOGLE_CLIENT_SECRET value that is actually an AIza... API key.
GOOGLE_MAPS_API_KEY=
JARVIS_GOOGLE_CLIENT_SECRET=/Users/chris/Desktop/CODE/JARVIS/config/google_client_secret.json
JARVIS_GOOGLE_TOKEN_PATH=/Users/chris/Desktop/CODE/JARVIS/data/google/google_token.json


# =============================================================================
# Microsoft Graph (optional)
# =============================================================================

JARVIS_MICROSOFT_CLIENT_ID=
JARVIS_MICROSOFT_TENANT_ID=
JARVIS_MICROSOFT_CLIENT_SECRET=
JARVIS_MICROSOFT_REDIRECT_URI=http://localhost:8787/auth/microsoft/callback
JARVIS_MICROSOFT_TOKEN_PATH=/Users/chris/Desktop/CODE/JARVIS/data/microsoft_graph/token.json
JARVIS_MICROSOFT_AUTHORITY=common


# =============================================================================
# Plaid (optional live finance connector)
# =============================================================================

# Create credentials at: https://dashboard.plaid.com
# Products used: transactions
JARVIS_PLAID_CLIENT_ID=
JARVIS_PLAID_SECRET=
JARVIS_PLAID_ENV=sandbox
JARVIS_PLAID_COUNTRY_CODES=US
JARVIS_PLAID_WEBHOOK_URL=


# =============================================================================
# OpenWeather
# =============================================================================

# Weather connector — Alexandria VA (lat=38.8048, lon=-77.0469) is the default
# https://openweathermap.org/api
OPENWEATHER_API_KEY=your-openweather-key-here


# =============================================================================
# OpenViking Memory (optional)
# =============================================================================

# OpenViking is installed locally — enable it.
# Run: openviking-server init && openviking-server
# Workspace defaults to ~/openviking_workspace (set in ~/.openviking/ov.conf)
JARVIS_OPENVIKING_ENABLED=true
OPENVIKING_BASE_URL=http://127.0.0.1:1933
OPENVIKING_API_KEY=
OPENVIKING_ACCOUNT=default
OPENVIKING_USER=chris
OPENVIKING_AGENT_ID=jarvis
# Memories stored under viking://user/chris/memories/{type}-{id}.md
JARVIS_OPENVIKING_MEMORY_URI_ROOT=viking://user/chris/memories/


# =============================================================================
# Misc
# =============================================================================

YOUR_NAME=Chris
OPENCLAW_GATEWAY_URL=ws://127.0.0.1:18789


# =============================================================================
# Ghostwritr Integration
# =============================================================================

# Base URL for the Ghostwritr Next.js app (default: http://localhost:3000)
GHOSTWRITR_BASE_URL=http://localhost:3000

# PostgreSQL connection string for direct DB reads (Prisma schema)
GHOSTWRITR_DB_URL=postgresql://postgres:postgres@localhost:5432/book_platform_builder

# Internal workflow token — required to trigger workflow runs via
# POST /api/internal/workflow-runs/process (x-internal-workflow-token header)
GHOSTWRITR_INTERNAL_TOKEN=
