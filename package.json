    "test:fallback": "node ./tests/fallback-classification.test.js",
    "test:fallback-analysis": "node ./tests/fallback-analysis.test.js",
    "test:ontology": "node ./tests/ontology-v1.test.js",
    "test:voice": "node ./tests/voice-translator.test.js",
    "test:workspace": "node ./tests/workspace-materializer.test.js",
    "test:contract": "node ./tests/runtime-contract-enforcer.test.js",
    "test:continuity": "node ./tests/continuity-resolver.test.js",
    "test:learning": "node ./tests/closed-loop-learning.test.js",
    "test:calendar": "node ./tests/calendar-context.test.js",
    "test:daily-brief": "node ./tests/daily-brief-usefulness.test.js",
    "test:daily-brief-ollama": "node ./tests/daily-brief-ollama.test.js",
    "test:documents": "node ./tests/documents-context.test.js",
    "test:email": "node ./tests/email-context.test.js",
    "test:finances": "node ./tests/financial-context.test.js",
    "test:intelligence-guard": "node ./tests/intelligence-guard.test.js",
    "test:personalization": "node ./tests/personalization.test.js",
    "test:personal": "node ./tests/personal-store.test.js",
    "test:capture": "node ./tests/capture-usefulness.test.js",
    "test:capture-response": "node ./tests/capture-response.test.js",
    "test:review": "node ./tests/review-analysis.test.js",
    "test:thread-recall": "node ./tests/thread-recall.test.js",
    "test:usefulness": "node ./tests/usefulness-regression.test.js",
    "test:usefulness-evaluator": "node ./tests/usefulness-evaluator.test.js",
    "test:canonical": "node ./tests/canonical-conversations.test.js",
    "test:behavioral": "node ./tests/behavioral.test.js",
    "test:behavioral:ollama": "MONDAY_OLLAMA_ENABLED=true node ./tests/behavioral.test.js",
    "test:pkm": "node ./tests/pkm-pipeline.test.js",
    "test:pkm:e2e": "node ./tests/pkm-e2e.test.js",
