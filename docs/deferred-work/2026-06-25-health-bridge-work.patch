diff --git a/src/engine/health/bridge-store.js b/src/engine/health/bridge-store.js
new file mode 100644
index 0000000..7ccd17c
--- /dev/null
+++ b/src/engine/health/bridge-store.js
@@ -0,0 +1,336 @@
+"use strict";
+
+const fs = require("node:fs");
+const os = require("node:os");
+const path = require("node:path");
+
+const Database = require("better-sqlite3");
+
+function resolveMondayHealthDir() {
+  if (process.env.MONDAY_HEALTH_DIR) return process.env.MONDAY_HEALTH_DIR;
+  return path.resolve(__dirname, "../../../data/health");
+}
+
+function resolveJarvisHealthDir() {
+  if (process.env.MONDAY_JARVIS_HEALTH_DIR) return process.env.MONDAY_JARVIS_HEALTH_DIR;
+  return path.join(os.homedir(), ".jarvis", "health");
+}
+
+function ensureDir(dirPath) {
+  fs.mkdirSync(dirPath, { recursive: true });
+}
+
+function filePath(name) {
+  const dir = resolveMondayHealthDir();
+  ensureDir(dir);
+  return path.join(dir, name);
+}
+
+function appendJsonl(file, payload) {
+  fs.appendFileSync(file, `${JSON.stringify(payload)}\n`, "utf8");
+}
+
+function readJson(file, fallback) {
+  try {
+    if (!fs.existsSync(file)) return cloneFallback(fallback);
+    return JSON.parse(fs.readFileSync(file, "utf8"));
+  } catch {
+    return cloneFallback(fallback);
+  }
+}
+
+function writeJson(file, payload) {
+  const tmp = `${file}.tmp`;
+  fs.writeFileSync(tmp, JSON.stringify(payload, null, 2), "utf8");
+  fs.renameSync(tmp, file);
+}
+
+function cloneFallback(value) {
+  if (Array.isArray(value)) return [...value];
+  if (value && typeof value === "object") return { ...value };
+  return value;
+}
+
+function nowIso() {
+  return new Date().toISOString();
+}
+
+function defaultBridgeState() {
+  return {
+    lastUpdated: null,
+    sources: {},
+    latestMetrics: {},
+    recentSignals: [],
+  };
+}
+
+function loadBridgeState() {
+  return readJson(filePath("bridge-state.json"), defaultBridgeState());
+}
+
+function saveBridgeState(state) {
+  const payload = {
+    ...defaultBridgeState(),
+    ...state,
+    lastUpdated: state.lastUpdated || nowIso(),
+  };
+  writeJson(filePath("bridge-state.json"), payload);
+  appendJsonl(filePath("bridge-state-log.jsonl"), {
+    savedAt: nowIso(),
+    state: payload,
+  });
+  return payload;
+}
+
+const METRIC_MAP = {
+  sleep_duration: "sleep_hours",
+  sleep_hours: "sleep_hours",
+  steps: "steps",
+  active_energy: "active_calories",
+  active_calories: "active_calories",
+  exercise_minutes: "exercise_minutes",
+  resting_heart_rate: "resting_hr",
+  resting_hr: "resting_hr",
+  heart_rate_variability: "hrv",
+  hrv: "hrv",
+  weight: "weight",
+  body_weight: "weight",
+  blood_glucose: "glucose_mg_dl",
+  glucose: "glucose_mg_dl",
+  blood_pressure_systolic: "systolic_bp",
+  blood_pressure_diastolic: "diastolic_bp",
+  oxygen_saturation: "blood_oxygen",
+  blood_oxygen: "blood_oxygen",
+};
+
+function normalizeSignal(signal, source = "unknown") {
+  const metric = String(signal.metric || signal.name || "").trim();
+  const normalizedMetric = METRIC_MAP[metric] || metric;
+  const timestamp = signal.timestamp || signal.captured_at || signal.observed_at || nowIso();
+  return {
+    metric,
+    normalizedMetric,
+    value: signal.value,
+    unit: signal.unit || null,
+    source: signal.source || signal.provenance || source,
+    timestamp,
+    confidence: signal.confidence ?? null,
+    raw: signal,
+  };
+}
+
+function ingestHealthSync(payload = {}) {
+  const state = loadBridgeState();
+  const source = String(payload.source || "health_bridge").trim() || "health_bridge";
+  const syncedAt = payload.synced_at || nowIso();
+  const signals = Array.isArray(payload.signals) ? payload.signals : [];
+  const normalizedSignals = signals.map((signal) => normalizeSignal(signal, source));
+
+  const existingSource = state.sources[source] || {};
+  state.sources[source] = {
+    name: source,
+    lastSync: syncedAt,
+    signalCount: (existingSource.signalCount || 0) + normalizedSignals.length,
+    deviceContext: payload.device_context || existingSource.deviceContext || null,
+    lastPayloadSource: payload.source || source,
+  };
+
+  for (const signal of normalizedSignals) {
+    if (!signal.normalizedMetric) continue;
+    state.latestMetrics[signal.normalizedMetric] = {
+      value: signal.value,
+      unit: signal.unit,
+      source: signal.source,
+      observedAt: signal.timestamp,
+      metric: signal.metric,
+      confidence: signal.confidence,
+    };
+    state.recentSignals.unshift({
+      metric: signal.metric,
+      normalizedMetric: signal.normalizedMetric,
+      value: signal.value,
+      unit: signal.unit,
+      source: signal.source,
+      observedAt: signal.timestamp,
+    });
+  }
+  state.recentSignals = state.recentSignals.slice(0, 200);
+  state.lastUpdated = syncedAt;
+  saveBridgeState(state);
+
+  return {
+    ok: true,
+    source,
+    syncedAt,
+    receivedSignals: normalizedSignals.length,
+    latestMetrics: state.latestMetrics,
+  };
+}
+
+function getCurrentBridgeStatus() {
+  const state = loadBridgeState();
+  const dexcomTokenPresent = dexcomTokenCandidates().some((candidate) => fs.existsSync(candidate));
+  const jarvisDir = resolveJarvisHealthDir();
+  return {
+    ok: true,
+    bridgeReady: true,
+    lastUpdated: state.lastUpdated,
+    sourceCount: Object.keys(state.sources || {}).length,
+    liveSources: state.sources,
+    dexcomConfigured: dexcomTokenPresent || Boolean(process.env.DEXCOM_CLIENT_ID),
+    jarvisHealthDir: jarvisDir,
+    jarvisHealthDirExists: fs.existsSync(jarvisDir),
+    mychartImported: Boolean(getMyChartSummary().hasData),
+  };
+}
+
+function dexcomTokenCandidates() {
+  return [
+    path.join(resolveMondayHealthDir(), "dexcom_tokens.json"),
+    path.join(resolveJarvisHealthDir(), "dexcom_tokens.json"),
+    path.join(os.homedir(), ".jarvis", "dexcom_tokens.json"),
+  ];
+}
+
+function withReadonlyDb(callback, fallback = null) {
+  const dbPath = path.join(resolveJarvisHealthDir(), "health.db");
+  if (!fs.existsSync(dbPath)) return fallback;
+  const db = new Database(dbPath, { readonly: true, fileMustExist: true });
+  try {
+    return callback(db);
+  } catch {
+    return fallback;
+  } finally {
+    db.close();
+  }
+}
+
+function safeSingle(db, sql) {
+  try {
+    return db.prepare(sql).get() || null;
+  } catch {
+    return null;
+  }
+}
+
+function safeAll(db, sql) {
+  try {
+    return db.prepare(sql).all() || [];
+  } catch {
+    return [];
+  }
+}
+
+function getJarvisRuntimeSummary() {
+  const jarvisDir = resolveJarvisHealthDir();
+  const files = {
+    healthState: path.join(jarvisDir, "chris_health_state.json"),
+    mychartRecords: path.join(jarvisDir, "mychart_records.json"),
+  };
+  const state = fs.existsSync(files.healthState) ? readJson(files.healthState, {}) : {};
+  const dbSummary = withReadonlyDb((db) => ({
+    counts: {
+      daily_metrics: safeSingle(db, "SELECT COUNT(*) AS rows FROM daily_metrics")?.rows || 0,
+      test_results: safeSingle(db, "SELECT COUNT(*) AS rows FROM test_results")?.rows || 0,
+      bp_readings: safeSingle(db, "SELECT COUNT(*) AS rows FROM bp_readings")?.rows || 0,
+      glucose_readings: safeSingle(db, "SELECT COUNT(*) AS rows FROM glucose_readings")?.rows || 0,
+      mychart_pages: safeSingle(db, "SELECT COUNT(*) AS rows FROM mychart_pages")?.rows || 0,
+    },
+    latestMetric: safeSingle(
+      db,
+      "SELECT date, source, steps, resting_hr, hrv, sleep_hours, blood_oxygen, weight FROM daily_metrics ORDER BY date DESC LIMIT 1"
+    ),
+    latestBp: safeSingle(
+      db,
+      "SELECT reading_date, source, systolic, diastolic, pulse FROM bp_readings ORDER BY reading_date DESC LIMIT 1"
+    ),
+    latestGlucose: safeSingle(
+      db,
+      "SELECT reading_time, source, glucose_mgdl, trend, trend_rate FROM glucose_readings ORDER BY reading_time DESC LIMIT 1"
+    ),
+    mychartPages: safeAll(db, "SELECT page_key, page_type, synced_at FROM mychart_pages ORDER BY synced_at DESC LIMIT 8"),
+  }), {
+    counts: {},
+    latestMetric: null,
+    latestBp: null,
+    latestGlucose: null,
+    mychartPages: [],
+  });
+
+  return {
+    jarvisHealthDir: jarvisDir,
+    available: fs.existsSync(jarvisDir),
+    healthStateUpdatedAt: state?.metadata?.last_updated || null,
+    counts: dbSummary.counts,
+    latestMetric: dbSummary.latestMetric,
+    latestBp: dbSummary.latestBp,
+    latestGlucose: dbSummary.latestGlucose,
+    mychartPages: dbSummary.mychartPages,
+    importedConditions: Array.isArray(state?.medical_history?.known_conditions)
+      ? state.medical_history.known_conditions.slice(0, 5).map((item) => item.name).filter(Boolean)
+      : [],
+  };
+}
+
+function getMyChartSummary() {
+  const recordsPath = path.join(resolveJarvisHealthDir(), "mychart_records.json");
+  const records = fs.existsSync(recordsPath) ? readJson(recordsPath, {}) : {};
+  const pageKeys = Object.keys(records).filter((key) => key !== "last_updated");
+  return {
+    hasData: pageKeys.length > 0,
+    lastUpdated: records.last_updated || null,
+    pages: pageKeys,
+    previews: pageKeys.slice(0, 6).map((key) => ({
+      page: key,
+      scrapedAt: records[key]?.scraped_at || null,
+      preview: String(records[key]?.content || "").slice(0, 140),
+    })),
+  };
+}
+
+function buildHealthSummary() {
+  const bridge = loadBridgeState();
+  const jarvis = getJarvisRuntimeSummary();
+  const mychart = getMyChartSummary();
+  const latestMetrics = bridge.latestMetrics || {};
+
+  const headlineParts = [];
+  if (latestMetrics.sleep_hours?.value != null) headlineParts.push(`sleep ${latestMetrics.sleep_hours.value}h`);
+  if (latestMetrics.resting_hr?.value != null) headlineParts.push(`resting HR ${latestMetrics.resting_hr.value}`);
+  if (latestMetrics.steps?.value != null) headlineParts.push(`${latestMetrics.steps.value} steps`);
+  if (latestMetrics.glucose_mg_dl?.value != null) headlineParts.push(`glucose ${latestMetrics.glucose_mg_dl.value}`);
+
+  const importedParts = [];
+  if (jarvis.latestMetric?.date) importedParts.push(`latest JARVIS metric ${jarvis.latestMetric.date}`);
+  if ((jarvis.counts?.test_results || 0) > 0) importedParts.push(`${jarvis.counts.test_results} labs imported`);
+  if (mychart.hasData) importedParts.push(`${mychart.pages.length} MyChart page snapshots`);
+
+  const summaryText = headlineParts.length
+    ? `Live bridge is receiving health signals: ${headlineParts.join(", ")}.`
+    : importedParts.length
+      ? `Health has imported history available: ${importedParts.join(", ")}.`
+      : "Health bridge is ready, but no live signals have reached Monday yet.";
+
+  return {
+    status: headlineParts.length ? "live" : importedParts.length ? "history_only" : "ready_for_bridge",
+    summaryText,
+    lastUpdated: bridge.lastUpdated || jarvis.healthStateUpdatedAt || null,
+    latestMetrics,
+    sourceCount: Object.keys(bridge.sources || {}).length,
+    liveSources: bridge.sources || {},
+    jarvis,
+    mychart,
+  };
+}
+
+module.exports = {
+  buildHealthSummary,
+  getCurrentBridgeStatus,
+  getJarvisRuntimeSummary,
+  getMyChartSummary,
+  ingestHealthSync,
+  loadBridgeState,
+  resolveJarvisHealthDir,
+  resolveMondayHealthDir,
+  saveBridgeState,
+};
diff --git a/tests/health-bridge.test.js b/tests/health-bridge.test.js
new file mode 100644
index 0000000..9de094f
