+++ b/tests/health-bridge.test.js
@@ -0,0 +1,102 @@
+"use strict";
+
+const test = require("node:test");
+const assert = require("node:assert/strict");
+const fs = require("node:fs");
+const os = require("node:os");
+const path = require("node:path");
+const Database = require("better-sqlite3");
+
+function resetModules() {
+  for (const key of Object.keys(require.cache)) {
+    if (
+      key.includes("/src/engine/health/bridge-store") ||
+      key.includes("/src/engine/gateway/presenter-state")
+    ) {
+      delete require.cache[key];
+    }
+  }
+}
+
+test("health bridge ingests normalized live signals", () => {
+  const tempRoot = fs.mkdtempSync(path.join(os.tmpdir(), "monday-health-bridge-"));
+  process.env.MONDAY_HEALTH_DIR = tempRoot;
+  process.env.MONDAY_JARVIS_HEALTH_DIR = path.join(tempRoot, "jarvis");
+  resetModules();
+
+  const { ingestHealthSync, buildHealthSummary } = require("../src/engine/health/bridge-store");
+  const result = ingestHealthSync({
+    source: "jarvis_iphone",
+    synced_at: "2026-06-25T12:00:00.000Z",
+    signals: [
+      { metric: "sleep_duration", timestamp: "2026-06-25T06:30:00.000Z", value: 7.1, unit: "h", source: "healthkit" },
+      { metric: "resting_heart_rate", timestamp: "2026-06-25T06:30:00.000Z", value: 57, unit: "bpm", source: "healthkit" },
+      { metric: "steps", timestamp: "2026-06-25T12:00:00.000Z", value: 4200, unit: "count", source: "healthkit" },
+    ],
+    device_context: { platform: "ios", watch_paired: true, healthkit_available: true },
+  });
+
+  assert.equal(result.ok, true);
+  assert.equal(result.receivedSignals, 3);
+
+  const summary = buildHealthSummary();
+  assert.equal(summary.status, "live");
+  assert.equal(summary.latestMetrics.sleep_hours.value, 7.1);
+  assert.equal(summary.latestMetrics.resting_hr.value, 57);
+  assert.match(summary.summaryText, /Live bridge is receiving health signals/i);
+});
+
+test("health summary pulls imported JARVIS runtime and MyChart records", () => {
+  const tempRoot = fs.mkdtempSync(path.join(os.tmpdir(), "monday-health-jarvis-"));
+  const mondayHealthDir = path.join(tempRoot, "monday");
+  const jarvisHealthDir = path.join(tempRoot, "jarvis");
+  fs.mkdirSync(mondayHealthDir, { recursive: true });
+  fs.mkdirSync(jarvisHealthDir, { recursive: true });
+
+  fs.writeFileSync(
+    path.join(jarvisHealthDir, "mychart_records.json"),
+    JSON.stringify({
+      last_updated: "2026-06-24T09:00:00.000Z",
+      medications: { scraped_at: "2026-06-24T08:00:00.000Z", content: "Aspirin 81mg daily" },
+    }),
+    "utf8"
+  );
+  fs.writeFileSync(
+    path.join(jarvisHealthDir, "chris_health_state.json"),
+    JSON.stringify({
+      metadata: { last_updated: "2026-06-24" },
+      medical_history: { known_conditions: [{ name: "Type 2 diabetes mellitus" }] },
+    }),
+    "utf8"
+  );
+
+  const db = new Database(path.join(jarvisHealthDir, "health.db"));
+  db.exec(`
+    CREATE TABLE daily_metrics (date TEXT, source TEXT, steps INTEGER, resting_hr REAL, hrv REAL, sleep_hours REAL, blood_oxygen REAL, weight REAL);
+    CREATE TABLE test_results (test_name TEXT, result_date TEXT, value TEXT);
+    CREATE TABLE bp_readings (reading_date TEXT, source TEXT, systolic INTEGER, diastolic INTEGER, pulse INTEGER);
+    CREATE TABLE glucose_readings (reading_time TEXT, source TEXT, glucose_mgdl INTEGER, trend TEXT, trend_rate REAL);
+    CREATE TABLE mychart_pages (page_key TEXT, page_type TEXT, synced_at TEXT);
+  `);
+  db.prepare("INSERT INTO daily_metrics VALUES (?, ?, ?, ?, ?, ?, ?, ?)").run("2026-06-24", "apple_health", 8123, 58, 44, 7.2, 98, 201.5);
+  db.prepare("INSERT INTO test_results VALUES (?, ?, ?)").run("HGB A1C", "2026-06-24", "7.1");
+  db.prepare("INSERT INTO bp_readings VALUES (?, ?, ?, ?, ?)").run("2026-06-24T07:00:00.000Z", "manual", 128, 82, 68);
+  db.prepare("INSERT INTO mychart_pages VALUES (?, ?, ?)").run("medications", "html", "2026-06-24T08:00:00.000Z");
+  db.close();
+
+  process.env.MONDAY_HEALTH_DIR = mondayHealthDir;
+  process.env.MONDAY_JARVIS_HEALTH_DIR = jarvisHealthDir;
+  resetModules();
+
+  const { buildHealthSummary } = require("../src/engine/health/bridge-store");
+  const { buildPresenterState } = require("../src/engine/gateway/presenter-state");
+
+  const summary = buildHealthSummary();
+  assert.equal(summary.status, "history_only");
+  assert.equal(summary.jarvis.counts.test_results, 1);
+  assert.equal(summary.mychart.hasData, true);
+  assert.match(summary.summaryText, /Health has imported history available/i);
+
+  const presenter = buildPresenterState();
+  assert.match(presenter.subjects.health.summary, /Health has imported history available/i);
+});
