+"use strict";
+
+const { getContradictions } = require("../db/knowledge-store");
+const { nextSurfacingItem } = require("../db/surfacing-store");
+
+const SIGNIFICANCE_LEVELS = {
+  chris: 0.78,
+  retirement: 0.96,
+  family: 0.95,
+  faith: 0.88,
+  publishing: 0.82,
+  work: 0.84,
+  health: 0.86,
+  "summer-camp": 0.74,
+};
+
+function hoursSince(isoString) {
+  if (!isoString) return null;
+  const parsed = Date.parse(isoString);
+  if (Number.isNaN(parsed)) return null;
+  return (Date.now() - parsed) / (1000 * 60 * 60);
+}
+
+function contradictionSeverityForDomain(domain) {
+  try {
+    const contradictions = getContradictions({ domain, status: "active" });
+    return contradictions.length;
+  } catch {
+    return 0;
+  }
+}
+
+function significanceForSubject(subject) {
+  return SIGNIFICANCE_LEVELS[subject.id] || 0.7;
+}
+
+function stewardshipState(conversation) {
+  if (conversation.status === "Blocked") return "blocked";
+  if (conversation.status === "Resolved") return "resolved";
+  if (conversation.status === "Paused") return "paused";
+  if (conversation.status === "Ready" || conversation.status === "Revising") return "ready";
+  if (conversation.status === "Discussing") return "active";
+  if (conversation.status === "Researching") return "researching";
+  return "watching";
+}
+
+function freshnessScore(conversation) {
+  const age =
+    hoursSince(conversation.lastTheoryChangedAt) ??
+    hoursSince(conversation.lastProgressAt) ??
+    hoursSince(conversation.lastUpdatedAt);
+  if (age === null) return 0.45;
+  if (age <= 4) return 1;
+  if (age <= 12) return 0.82;
+  if (age <= 24) return 0.68;
+  if (age <= 72) return 0.52;
+  return 0.28;
+}
+
+function elapsedSurfaceScore(conversation) {
+  const age = hoursSince(conversation.lastTouchedAt || conversation.lastUserAttentionAt);
+  if (age === null) return 0.72;
+  if (age <= 2) return 0.12;
+  if (age <= 12) return 0.3;
+  if (age <= 24) return 0.55;
+  if (age <= 72) return 0.74;
+  return 0.92;
+}
+
+function userAttentionPenalty(conversation) {
+  const age = hoursSince(conversation.lastUserAttentionAt || conversation.lastTouchedAt);
+  if (age === null) return 0;
+  if (age <= 1.5) return 0.18;
+  if (age <= 6) return 0.09;
+  return 0;
+}
+
+function deriveUrgency(conversation, contradictionSeverity, significanceLevel) {
+  if (conversation.status === "Blocked") return "blocked";
+  if (conversation.status === "Resolved") return "quiet";
+  if (contradictionSeverity >= 3 && significanceLevel >= 0.9) return "important";
+  if (conversation.status === "Ready" || conversation.status === "Revising") return "important";
+  if (conversation.currentReadDecision === "wait" || conversation.currentReadStale) return "watching";
+  return "watching";
+}
+
+function quietReasonForCandidate({
+  significanceLevel,
+  contradictionSeverity,
+  confidence,
+  freshness,
+  conversation,
+}) {
+  if (conversation.status === "Blocked") return "Blocked.";
+  if (conversation.status === "Resolved") return "Resolved.";
+  if (conversation.currentReadDecision === "wait" || confidence < 0.5) {
+    return "The read is not stable enough yet.";
+  }
+  if (contradictionSeverity > 0 && conversation.status === "Watching") {
+    return "It matters, but it is not ripe for action yet.";
+  }
+  if (significanceLevel >= 0.88 && freshness < 0.6) {
+    return "It matters, but there is not enough fresh evidence today.";
+  }
+  if (conversation.status === "Watching") return "It is being watched, but it is not asking for the floor.";
+  return "Nothing here is asking to interrupt first.";
+}
+
+function deriveCandidateMode({
+  isCurrent,
+  unresolvedRecommendation,
+  changedMaterially,
+  contradictionSeverity,
+  opportunityRipeness,
+  confidence,
+  quietButImportant,
+  conversation,
+  pendingSurfacingMatch,
+}) {
+  if (pendingSurfacingMatch && confidence >= 0.5) return "surface_change";
+  if (
+    isCurrent &&
+    conversation.status !== "Resolved" &&
+    conversation.status !== "Blocked" &&
+    (conversation.status === "Discussing" ||
+      conversation.status === "Paused" ||
+      unresolvedRecommendation ||
+      conversation.unresolvedQuestion)
+  ) {
+    return "continue_current";
+  }
+  if (contradictionSeverity >= 2 && confidence >= 0.54) return "surface_contradiction";
+  if (
+    changedMaterially &&
+    confidence >= 0.58
+  ) return "surface_change";
+  if (
+    !isCurrent &&
+    conversation.status !== "Resolved" &&
+    (unresolvedRecommendation || conversation.unresolvedQuestion || conversation.status === "Paused")
+  ) {
+    return "return_to_unfinished";
+  }
+  if (opportunityRipeness >= 0.68 && confidence >= 0.56) return "surface_opportunity";
+  if (quietButImportant) return "do_not_interrupt";
+  if (conversation.status === "Watching") return "quiet_watch";
+  return "no_clear_priority";
+}
+
+function shouldSurfaceForMode(mode) {
+  return [
+    "continue_current",
+    "return_to_unfinished",
+    "surface_change",
+    "surface_contradiction",
+    "surface_opportunity",
+  ].includes(mode);
+}
+
+function reasonForMode(mode, subject, conversation, contradictionSeverity, opportunityRipeness) {
+  switch (mode) {
+    case "continue_current":
+      return `The ${subject.name} conversation is still alive and unresolved.`;
+    case "return_to_unfinished":
+      return `We left a real ${subject.name} thought unresolved.`;
+    case "surface_change":
+      return `The ${subject.name} read changed materially.`;
+    case "surface_contradiction":
+      return `${subject.name} has a contradiction that is getting harder to ignore.`;
+    case "surface_opportunity":
+      return `${subject.name} has an opportunity that looks ripe enough to use.`;
+    case "do_not_interrupt":
+      return `${subject.name} matters, but timing is wrong.`;
+    case "quiet_watch":
+      return `${subject.name} is being watched quietly.`;
+    default:
+      return `${subject.name} does not have a stronger claim on attention right now.`;
+  }
+}
+
+function buildCandidate({ subject, conversation, envelope, pendingSurfacing, contradictionOverride = null }) {
+  const significanceLevel = significanceForSubject(subject);
+  const contradictionSeverity =
+    contradictionOverride ?? contradictionSeverityForDomain(subject.domain || subject.name);
+  const confidence = Number(conversation.currentReadConfidence ?? 0.5);
+  const freshness = freshnessScore(conversation);
+  const unresolvedRecommendation = Boolean(
+    conversation.currentRecommendation &&
+    conversation.unresolved !== false &&
+    conversation.status !== "Resolved"
+  );
+  const changedMaterially = Boolean(
+    conversation.driftMemory?.centerShifted ||
+    conversation.status === "Revising" ||
+    (hoursSince(conversation.lastTheoryChangedAt) ?? Infinity) <= 24 ||
+    (conversation.currentReadLabels || []).includes("center shifted")
+  );
+  const opportunityRipeness =
+    conversation.currentOpportunity
+      ? Math.max(confidence, freshness)
+      : conversation.pendingRecommendation
+        ? Math.max(0.55, confidence)
+        : 0;
+  const workforceCompletion = conversation.latestWorkforceSignal ? 1 : 0;
+  const elapsedSinceLastSurfaced = elapsedSurfaceScore(conversation);
+  const recentAttentionPenalty = userAttentionPenalty(conversation);
+  const isCurrent = envelope.activeSubjectId === subject.id;
+  const urgency = deriveUrgency(conversation, contradictionSeverity, significanceLevel);
+  const quietButImportant =
+    significanceLevel >= 0.88 &&
+    !changedMaterially &&
+    !unresolvedRecommendation &&
+    contradictionSeverity <= 1 &&
+    (conversation.status === "Watching" || conversation.currentReadDecision === "wait");
+  const interruptibility =
+    isCurrent && recentAttentionPenalty > 0 ? "protected" : conversation.status === "Blocked" ? "blocked" : "open";
+  const pendingSurfacingMatch = Boolean(
+    pendingSurfacing &&
+    String(pendingSurfacing.domain || "").trim().toLowerCase() ===
+      String(subject.domain || subject.name).trim().toLowerCase()
+  );
+  const mode = deriveCandidateMode({
+    isCurrent,
+    unresolvedRecommendation,
+    changedMaterially,
+    contradictionSeverity,
+    opportunityRipeness,
+    confidence,
+    quietButImportant,
+    conversation,
+    pendingSurfacingMatch,
+  });
+  const shouldSurface = shouldSurfaceForMode(mode) && interruptibility !== "blocked";
+  const shouldStayQuiet = !shouldSurface || interruptibility === "protected";
+  const quietReason = shouldStayQuiet
+    ? quietReasonForCandidate({
+        significanceLevel,
+        contradictionSeverity,
+        confidence,
+        freshness,
+        conversation,
+      })
+    : null;
+  const stewardship = stewardshipState(conversation);
+
+  let score = significanceLevel * 30;
+  score += confidence * 16;
+  score += freshness * 10;
+  score += elapsedSinceLastSurfaced * 9;
+  score += contradictionSeverity * 5;
+  score += opportunityRipeness * 8;
+  score += workforceCompletion * 6;
+  score += unresolvedRecommendation ? 14 : 0;
+  score += changedMaterially ? 15 : 0;
+  score += isCurrent ? 7 : 0;
+  score -= recentAttentionPenalty * 16;
+  score -= shouldStayQuiet ? 8 : 0;
+  score -= stewardship === "resolved" ? 32 : 0;
+  score -= stewardship === "blocked" ? 18 : 0;
+  score += mode === "continue_current" ? 24 : 0;
+  score += mode === "return_to_unfinished" ? 14 : 0;
+  score += mode === "surface_change" ? 12 : 0;
+  score += mode === "surface_contradiction" ? 9 : 0;
+  score += mode === "surface_opportunity" ? 7 : 0;
+
+  if (pendingSurfacingMatch) {
+    score += 10;
+  }
+
+  const reason = reasonForMode(mode, subject, conversation, contradictionSeverity, opportunityRipeness);
+
+  return {
+    subjectId: subject.id,
+    subjectName: subject.name,
+    score: Number(score.toFixed(2)),
+    reason,
+    status: stewardship,
+    urgency,
+    shouldSurface,
+    shouldStayQuiet,
+    quietReason,
+    significanceLevel,
+    stewardshipState: stewardship,
+    currentReadConfidence: confidence,
+    currentReadFreshness: freshness,
+    unresolvedRecommendation,
+    contradictionSeverity,
+    opportunityRipeness,
+    workforceCompletion,
+    recentAttentionPenalty,
+    elapsedSinceLastSurfaced,
+    interruptibility,
+    quietButImportant,
+    mode,
+  };
+}
+
+function buildWhyThis(candidate) {
+  switch (candidate.mode) {
+    case "continue_current":
+      return "The current conversation is still alive, and we left something real unresolved.";
+    case "return_to_unfinished":
+      return "We left a real recommendation or open thought unresolved.";
+    case "surface_change":
+      return "The read changed materially enough to deserve the floor.";
+    case "surface_contradiction":
+      return "A contradiction crossed the point where silence would be less faithful.";
+    case "surface_opportunity":
+      return "An opportunity became ripe enough that it is worth acting on.";
+    default:
+      return "This is the strongest available signal right now.";
+  }
+}
+
+function buildWhyNotOthers(selectedCandidate, sortedCandidates) {
+  return sortedCandidates
+    .filter((candidate) => candidate.subjectId !== selectedCandidate.subjectId)
+    .slice(0, 3)
+    .map((candidate) => ({
+      subjectId: candidate.subjectId,
+      subjectName: candidate.subjectName,
+      reason: candidate.shouldStayQuiet
+        ? candidate.quietReason || `${candidate.subjectName} is not ready yet.`
+        : `${candidate.subjectName} matters, but it has a weaker claim on attention than ${selectedCandidate.subjectName} right now.`,
+      status: candidate.shouldStayQuiet ? "quiet" : "watching",
+    }));
+}
+
+function chooseAttentionCandidate(sortedCandidates) {
+  const surfaceable = sortedCandidates.filter((candidate) => candidate.shouldSurface);
+  if (!surfaceable.length) return null;
+  const top = surfaceable[0];
+  if (top.score < 34) return null;
+  return top;
+}
+
+function deriveAttentionDecision(presenterState, envelope, options = {}) {
+  const pendingSurfacing = options.pendingSurfacing || nextSurfacingItem();
+  const requestedSubjectId =
+    options.requestedSubjectId && options.requestedSubjectId !== "daily"
+      ? options.requestedSubjectId
+      : null;
+
+  const candidates = Object.values(presenterState.subjects || {})
+    .map((subject) =>
+      buildCandidate({
+        subject,
+        conversation: envelope.subjects[subject.id],
+        envelope,
+        pendingSurfacing,
+        contradictionOverride: options.contradictionSeverityBySubject?.[subject.id] ?? null,
+      })
+    )
+    .sort((a, b) => b.score - a.score);
+
+  if (requestedSubjectId && presenterState.subjects[requestedSubjectId]) {
+    const requested = candidates.find((candidate) => candidate.subjectId === requestedSubjectId);
+    const whyNotOthers = requested ? buildWhyNotOthers(requested, candidates) : [];
+    return {
+      selectedSubjectId: requestedSubjectId,
+      selectedSubjectName: presenterState.subjects[requestedSubjectId].name,
+      selectedReason: "Chris explicitly steered the conversation here.",
+      selectedMode: "continue_current",
+      confidence: requested?.currentReadConfidence ?? 0.7,
+      urgency: requested?.urgency || "watching",
+      whyThis: "Chris chose to stay with this subject.",
+      whyNotOthers,
+      candidates,
+    };
+  }
+
+  const selected = chooseAttentionCandidate(candidates);
+  if (!selected) {
+    return {
+      selectedSubjectId: null,
+      selectedSubjectName: null,
+      selectedReason: "Nothing has a strong enough claim on attention right now.",
+      selectedMode: "no_clear_priority",
+      confidence: 0.42,
+      urgency: "watching",
+      whyThis: "No subject deserves to interrupt first.",
+      whyNotOthers: candidates.slice(0, 3).map((candidate) => ({
+        subjectId: candidate.subjectId,
+        subjectName: candidate.subjectName,
+        reason: candidate.shouldStayQuiet
+          ? candidate.quietReason || `${candidate.subjectName} is staying quiet.`
+          : `${candidate.subjectName} does not have a strong enough claim on attention right now.`,
+        status: candidate.shouldStayQuiet ? "quiet" : "watching",
+      })),
+      candidates,
+    };
+  }
+
+  return {
+    selectedSubjectId: selected.subjectId,
+    selectedSubjectName: selected.subjectName,
+    selectedReason: selected.reason,
+    selectedMode: selected.mode,
+    confidence: selected.currentReadConfidence,
+    urgency: selected.urgency,
+    whyThis: buildWhyThis(selected),
+    whyNotOthers: buildWhyNotOthers(selected, candidates),
+    candidates,
+  };
+}
+
+module.exports = {
+  deriveAttentionDecision,
+};
