+"use strict";
+
+const assert = require("node:assert/strict");
+const { deriveAttentionDecision } = require("../src/engine/conversation/attention-engine");
+
+function baseConversation(overrides = {}) {
+  return {
+    status: "Watching",
+    currentReadConfidence: 0.6,
+    currentReadDecision: "hold",
+    currentReadStale: false,
+    currentReadLabels: [],
+    currentRecommendation: null,
+    currentOpportunity: null,
+    pendingRecommendation: null,
+    unresolved: true,
+    unresolvedQuestion: null,
+    latestWorkforceSignal: null,
+    driftMemory: {
+      centerShifted: false,
+      durability: "fragile",
+      volatility: "low",
+    },
+    lastTheoryChangedAt: null,
+    lastProgressAt: null,
+    lastUpdatedAt: new Date(Date.now() - 12 * 60 * 60 * 1000).toISOString(),
+    lastTouchedAt: null,
+    lastUserAttentionAt: null,
+    ...overrides,
+  };
+}
+
+function run() {
+  const presenterState = {
+    subjects: {
+      retirement: { id: "retirement", name: "Retirement", domain: "Retirement" },
+      family: { id: "family", name: "Family", domain: "Family" },
+      health: { id: "health", name: "Health", domain: "Health" },
+      publishing: { id: "publishing", name: "Publishing", domain: "Publishing" },
+    },
+  };
+
+  const now = Date.now();
+  const envelope = {
+    activeSubjectId: "retirement",
+    lastSelectedSubjectId: "retirement",
+    subjects: {
+      retirement: baseConversation({
+        status: "Discussing",
+        currentReadConfidence: 0.78,
+        currentRecommendation: "Name the parts of work to lay down first.",
+        unresolvedQuestion: "What part of work is carrying too much?",
+        lastUserAttentionAt: new Date(now - 30 * 60 * 1000).toISOString(),
+      }),
+      family: baseConversation({
+        status: "Watching",
+        currentReadConfidence: 0.75,
+        driftMemory: { centerShifted: false, durability: "durable", volatility: "low" },
+      }),
+      health: baseConversation({
+        status: "Watching",
+        currentReadConfidence: 0.44,
+        currentReadDecision: "wait",
+        currentReadStale: true,
+      }),
+      publishing: baseConversation({
+        status: "Watching",
+        currentReadConfidence: 0.64,
+        currentOpportunity: "The book thread is becoming writable again.",
+      }),
+    },
+  };
+
+  const unresolvedBeatsWeak = deriveAttentionDecision(presenterState, envelope, {
+    contradictionSeverityBySubject: {
+      retirement: 0,
+      family: 0,
+      health: 0,
+      publishing: 0,
+    },
+  });
+  assert.equal(unresolvedBeatsWeak.selectedSubjectId, "retirement");
+  assert.equal(unresolvedBeatsWeak.selectedMode, "continue_current");
+
+  const theoryShiftEnvelope = {
+    ...envelope,
+    activeSubjectId: "family",
+    subjects: {
+      ...envelope.subjects,
+      retirement: baseConversation({
+        status: "Revising",
+        currentReadConfidence: 0.82,
+        currentRecommendation: "Do not set a retirement date yet.",
+        currentReadLabels: ["center shifted"],
+        driftMemory: {
+          centerShifted: true,
+          durability: "durable",
+          volatility: "medium",
+        },
+        lastTheoryChangedAt: new Date(now - 60 * 60 * 1000).toISOString(),
+      }),
+      family: baseConversation({
+        status: "Discussing",
+        currentReadConfidence: 0.54,
+        lastUserAttentionAt: new Date(now - 10 * 60 * 1000).toISOString(),
+      }),
+    },
+  };
+  const shiftBeatsRecent = deriveAttentionDecision(presenterState, theoryShiftEnvelope, {
+    contradictionSeverityBySubject: {
+      retirement: 0,
+      family: 0,
+      health: 0,
+      publishing: 0,
+    },
+  });
+  assert.equal(shiftBeatsRecent.selectedSubjectId, "retirement");
+  assert.equal(shiftBeatsRecent.selectedMode, "surface_change");
+
+  const contradictionEnvelope = {
+    ...envelope,
+    activeSubjectId: "health",
+    subjects: {
+      ...envelope.subjects,
+      family: baseConversation({
+        status: "Ready",
+        currentReadConfidence: 0.79,
+        currentReadDecision: "hold",
+        lastTheoryChangedAt: new Date(now - 3 * 60 * 60 * 1000).toISOString(),
+      }),
+      retirement: baseConversation({
+        status: "Watching",
+        currentReadConfidence: 0.62,
+        currentReadDecision: "wait",
+        currentRecommendation: null,
+      }),
+    },
+  };
+  const contradictionLead = deriveAttentionDecision(presenterState, contradictionEnvelope, {
+    contradictionSeverityBySubject: { family: 3 },
+  });
+  assert.equal(contradictionLead.selectedSubjectId, "family");
+  assert.equal(contradictionLead.selectedMode, "surface_contradiction");
+
+  const quietImportantEnvelope = {
+    ...envelope,
+    activeSubjectId: null,
+    subjects: {
+      retirement: baseConversation({
+        status: "Watching",
+        currentReadConfidence: 0.49,
+        currentReadDecision: "wait",
+        currentReadStale: true,
+      }),
+      family: baseConversation({
+        status: "Watching",
+        currentReadConfidence: 0.58,
+        currentReadDecision: "wait",
+      }),
+      health: baseConversation({
+        status: "Watching",
+        currentReadConfidence: 0.42,
+        currentReadDecision: "wait",
+        currentReadStale: true,
+      }),
+      publishing: baseConversation({
+        status: "Watching",
+        currentReadConfidence: 0.52,
+        currentReadDecision: "wait",
+      }),
+    },
+  };
+  const noPriority = deriveAttentionDecision(presenterState, quietImportantEnvelope, {
+    contradictionSeverityBySubject: {
+      retirement: 0,
+      family: 0,
+      health: 0,
+      publishing: 0,
+    },
+  });
+  assert.equal(noPriority.selectedMode, "no_clear_priority");
+  assert.equal(noPriority.selectedSubjectId, null);
+
+  const watchedHealth = noPriority.candidates.find((candidate) => candidate.subjectId === "health");
+  assert.equal(watchedHealth.shouldStayQuiet, true);
+
+  console.log("attention-engine: ok");
+}
+
+run();
